---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'fr' | 'en';
}

const { title, description = 'Portfolio de SkyCobra — Développeur XR.', lang = 'fr' } = Astro.props;

const base = import.meta.env.BASE_URL;
// Compose canonical URL: Astro.site is set in astro.config.mjs.
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://skycobra.github.io').toString();
const ogImage = new URL(`${base}og.png`, Astro.site ?? 'https://skycobra.github.io').toString();
const ogLocale = lang === 'fr' ? 'fr_FR' : 'en_US';
const ogLocaleAlt = lang === 'fr' ? 'en_US' : 'fr_FR';
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="SkyCobra" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:creator" content="@SkyC0bra" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=IM+Fell+English:ital@0;1&family=JetBrains+Mono:wght@400;500&family=Lora:ital,wght@0,400;0,500;1,400;1,500;1,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
