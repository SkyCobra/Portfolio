---
import type { Game, Lang } from '../data/portfolio';
import { GENRES, getTag, getRole, getGenreLabel, I18N } from '../data/portfolio';
import GenreGlyph from './GenreGlyph.astro';
import manifest from '../data/thumb-manifest.json';

interface Props {
  game: Game;
  lang: Lang;
  index: number;
}

const { game, lang, index } = Astro.props;
const t = I18N[lang];

const ROTATIONS = [-1.0, 0.7, -0.4, 1.1, -0.8, 0.5, -0.2, 0.9];
const rotation = ROTATIONS[index % ROTATIONS.length];

const PIN_COLORS = ['var(--wax)', '#3d6a8a', '#5a7a3a', '#a13a2a'];
const pinColor = PIN_COLORS[index % PIN_COLORS.length];

const rune = game.rank === 'Apprenti' ? 'A' : game.rank === 'Compagnon' ? 'C' : 'M';

const studio = game.studio ?? t.soloAuthor;
const tag = getTag(game, lang);
const role = getRole(game, lang);
const genreLabel = getGenreLabel(game.genre, lang);
const glyph = GENRES[game.genre].glyph;

const thumbBase = import.meta.env.BASE_URL;
const ext = (manifest as Record<string, string>)[game.id];
const thumbPath = ext ? `${thumbBase}games/${game.id}.${ext}` : null;
---
<a class="quest" href={game.itch} target="_blank" rel="noopener" style={`--rot: ${rotation}deg; --pin: ${pinColor};`}>
  <span class="pin"></span>
  <div class="parchment parchment-texture">
    <div class="thumb" style={thumbPath ? `background-image: url('${thumbPath}'); background-size: cover; background-position: center;` : undefined}>
      {!thumbPath && <span class="placeholder body-italic">{game.title}</span>}
      <span class="corner tl"></span><span class="corner tr"></span>
      <span class="corner bl"></span><span class="corner br"></span>
    </div>
    <div class="title-row">
      <span class="glyph"><GenreGlyph kind={glyph} size={16} /></span>
      <span class="title cinzel">{game.title}</span>
      <span class="wax-seal"><span class="rune cinzel">{rune}</span></span>
    </div>
    <p class="desc body-italic">{tag}</p>
    <div class="footer">
      <span class="year mono">{game.year}</span>
      <span class="studio body-italic">{studio}</span>
    </div>
  </div>
  <div class="tooltip">
    <div class="tt-title cinzel">{game.title}</div>
    <div class="tt-tag body-italic">{tag}</div>
    <hr class="tt-rule" />
    <dl class="tt-spec">
      <div><dt class="mono">{t.spec.year}</dt><dd>{game.year}</dd></div>
      <div><dt class="mono">{t.spec.genre}</dt><dd>{genreLabel}</dd></div>
      <div><dt class="mono">{t.spec.platform}</dt><dd>{game.platform}</dd></div>
      <div><dt class="mono">{t.spec.studio}</dt><dd>{studio}</dd></div>
      <div><dt class="mono">{t.spec.role}</dt><dd>{role}</dd></div>
      <div><dt class="mono">{t.spec.tools}</dt><dd>{game.tools.join(' · ')}</dd></div>
    </dl>
  </div>
</a>

<style>
  .quest {
    position: relative;
    display: block;
    width: 188px;
    color: inherit;
  }
  .quest:hover .parchment {
    transform: rotate(var(--rot)) translateY(-2px);
    box-shadow:
      0 12px 22px rgba(0,0,0,.32),
      inset 0 0 0 1px rgba(120,80,40,.22),
      inset 0 0 24px rgba(120,80,40,.14);
  }
  .quest:hover .tooltip { opacity: 1; visibility: visible; }

  .pin {
    position: absolute;
    top: -5px;
    left: 50%;
    transform: translateX(-50%);
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #fff7c6 0%, var(--pin) 55%, #2a1408 100%);
    box-shadow: 0 1px 2px rgba(0,0,0,.45);
    z-index: 3;
  }

  .parchment {
    position: relative;
    padding: 14px 12px 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transform: rotate(var(--rot));
    transition: transform 200ms ease, box-shadow 200ms ease;
    background-color: var(--parchment-2);
    box-shadow:
      0 8px 18px rgba(0,0,0,.28),
      inset 0 0 0 1px rgba(120,80,40,.22),
      inset 0 0 24px rgba(120,80,40,.10);
    clip-path: polygon(0.5% 2%, 99% 0.5%, 99.5% 50%, 100% 98%, 50% 99.5%, 1% 99.5%, 0.5% 50%);
  }

  .thumb {
    position: relative;
    height: 110px;
    background-color: var(--parchment-3);
    box-shadow: inset 0 0 0 1px rgba(31,22,12,.5);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .placeholder {
    font-style: italic;
    font-size: 13px;
    color: var(--ink-3);
    text-align: center;
    padding: 8px;
  }
  .corner {
    position: absolute;
    width: 6px;
    height: 6px;
    border: 1.5px solid var(--accent-deep);
  }
  .corner.tl { top: 0; left: 0; border-right: 0; border-bottom: 0; }
  .corner.tr { top: 0; right: 0; border-left: 0; border-bottom: 0; }
  .corner.bl { bottom: 0; left: 0; border-right: 0; border-top: 0; }
  .corner.br { bottom: 0; right: 0; border-left: 0; border-top: 0; }

  .title-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .glyph { color: var(--accent-deep); display: flex; flex: 0 0 16px; }
  .title {
    flex: 1;
    font-weight: 600;
    font-size: 13.5px;
    letter-spacing: 0.02em;
    color: var(--ink-1);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .wax-seal {
    flex: 0 0 22px;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #ffd4a2 0%, var(--accent-wax, var(--wax)) 50%, #5a1810 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    clip-path: polygon(50% 0,61% 8%,71% 4%,77% 14%,89% 16%,89% 28%,99% 36%,93% 47%,99% 58%,89% 65%,89% 78%,77% 80%,71% 90%,61% 86%,50% 95%,39% 86%,29% 90%,23% 80%,11% 78%,11% 65%,1% 58%,7% 47%,1% 36%,11% 28%,11% 16%,23% 14%,29% 4%,39% 8%);
  }
  .rune { color: #fff4d6; font-weight: 700; font-size: 10px; line-height: 1; }

  .desc {
    font-size: 12.5px;
    color: var(--ink-2);
    line-height: 1.35;
    min-height: 32px;
    margin: 0;
  }

  .footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 4px;
    border-top: 1px dotted var(--ink-hair);
    gap: 6px;
  }
  .year {
    font-size: 9.5px;
    padding: 1px 5px;
    border: 1px solid var(--ink-hair);
    border-radius: 3px;
    color: var(--ink-3);
  }
  .studio {
    font-size: 12px;
    color: var(--ink-3);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 110px;
  }

  /* Tooltip */
  .tooltip {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    width: 280px;
    padding: 12px 14px;
    background: rgba(31,22,12,0.96);
    color: var(--parchment-1);
    border-radius: 8px;
    border-top: 2px solid var(--accent);
    box-shadow: 0 12px 30px rgba(0,0,0,.5);
    z-index: 50;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 150ms ease;
  }
  .tt-title { font-weight: 600; font-size: 14px; color: #fbeec4; letter-spacing: 0.04em; }
  .tt-tag { opacity: 0.9; margin-top: 2px; font-size: 13px; line-height: 1.35; }
  .tt-rule { border: 0; border-top: 1px solid rgba(244,236,214,.18); margin: 8px 0; }
  .tt-spec { margin: 0; display: grid; grid-template-columns: 1fr; gap: 4px; }
  .tt-spec > div { display: grid; grid-template-columns: 78px 1fr; align-items: baseline; }
  .tt-spec dt { font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(244,236,214,.55); margin: 0; }
  .tt-spec dd { margin: 0; font-size: 12.5px; }

  /* Mobile — disable random rotation so cards don't overflow the viewport,
     and hide the hover tooltip (tap targets the link directly). */
  @media (max-width: 600px) {
    .quest { width: 100%; max-width: 280px; }
    .parchment { transform: none !important; }
    .quest:hover .parchment { transform: translateY(-2px) !important; }
    .tooltip { display: none; }
    .thumb { height: 140px; }
  }

  /* Touch devices — disable hover-only tooltip to avoid sticky behavior on tap. */
  @media (hover: none) {
    .tooltip { display: none; }
  }
</style>
