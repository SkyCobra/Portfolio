---
interface Props {
  title: string;
  body: string;
}

const { title, body } = Astro.props;
---
<div class="empty parchment-texture">
  <div class="badge">
    <span class="cinzel">?</span>
  </div>
  <div class="copy">
    <div class="title cinzel">{title}</div>
    <div class="body fell">{body}</div>
  </div>
</div>

<style>
  .empty {
    display: flex;
    gap: 18px;
    align-items: center;
    max-width: 540px;
    padding: 14px 22px;
    margin: 0 auto;
    transform: rotate(-0.6deg);
    background-color: var(--parchment-2);
    box-shadow:
      0 8px 18px rgba(0,0,0,.28),
      inset 0 0 0 1px rgba(120,80,40,.22),
      inset 0 0 24px rgba(120,80,40,.10);
  }
  .badge {
    flex: 0 0 44px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, var(--accent-soft) 0%, var(--accent) 60%, var(--accent-deep) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fbeec4;
    font-weight: 700;
    font-size: 22px;
  }
  .title {
    font-weight: 600;
    font-size: 16px;
    color: var(--ink-1);
  }
  .body {
    font-style: italic;
    font-size: 13px;
    color: var(--ink-2);
    line-height: 1.4;
  }
</style>
