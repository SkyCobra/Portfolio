---
import type { Lang } from '../data/portfolio';
import { I18N, PROFILE } from '../data/portfolio';

interface Props {
  lang: Lang;
  langSwitchHref: string;
}

const { lang, langSwitchHref } = Astro.props;
const t = I18N[lang];
const profileClass = PROFILE.className[lang];
const guild = PROFILE.guild[lang];
---
<header class="header">
  <div class="plaque">
    <div class="plaque-inner">
      <span class="subtitle cinzel">{t.subtitle}</span>
      <h1 class="title cinzel">{t.title}</h1>
      <p class="pitch fell">{t.pitch}</p>
    </div>
  </div>
  <div class="sticker-wrap">
    <div class="top-controls">
      <a class="ctrl" href="https://www.linkedin.com/in/romain-castel/" target="_blank" rel="noopener" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
          <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8.34 18.5V9.83H5.67v8.67h2.67zM7 8.67a1.55 1.55 0 1 0 0-3.1 1.55 1.55 0 0 0 0 3.1zm11.5 9.83v-4.75c0-2.55-1.36-3.74-3.18-3.74-1.47 0-2.13.81-2.49 1.38V9.83h-2.66c.04.75 0 8.67 0 8.67h2.66v-4.84c0-.24.02-.48.09-.65.19-.48.63-.98 1.36-.98.96 0 1.34.73 1.34 1.79v4.68h2.88z"/>
        </svg>
        <span class="mono">LinkedIn</span>
      </a>
      <a class="ctrl" href="https://github.com/SkyCobra" target="_blank" rel="noopener" aria-label="GitHub">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
          <path d="M12 .5a12 12 0 0 0-3.79 23.4c.6.11.82-.26.82-.58v-2c-3.34.73-4.04-1.61-4.04-1.61-.54-1.38-1.33-1.75-1.33-1.75-1.09-.74.08-.72.08-.72 1.2.08 1.84 1.24 1.84 1.24 1.07 1.84 2.82 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.66-.3-5.46-1.33-5.46-5.93 0-1.31.47-2.38 1.24-3.22-.13-.31-.54-1.53.12-3.19 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.25 2.88.12 3.19.77.84 1.24 1.91 1.24 3.22 0 4.62-2.81 5.62-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58A12 12 0 0 0 12 .5z"/>
        </svg>
        <span class="mono">GitHub</span>
      </a>
      <a class="ctrl" href={langSwitchHref} aria-label="Switch language">
        <span class="mono">{t.langToggle}</span>
      </a>
    </div>
    <div class="sticker parchment-texture">
      <span class="pin"></span>
      <div class="sticker-grid">
        <svg class="avatar" viewBox="0 0 62 62" width="62" height="62" aria-hidden="true">
          <circle cx="31" cy="31" r="29" fill="var(--parchment-3)" stroke="var(--ink-1)" stroke-width="1.2" />
          <path d="M31 14 c-10 0 -16 8 -16 16 v8 h32 v-8 c0 -8 -6 -16 -16 -16 z" fill="var(--ink-1)" />
          <circle cx="25" cy="34" r="1.6" fill="#fbeec4" />
          <circle cx="37" cy="34" r="1.6" fill="#fbeec4" />
          <path d="M31 14 l4 -8 l-8 0 z" fill="var(--accent-deep)" />
          <path d="M18 45 c4 6 22 6 26 0" fill="none" stroke="var(--ink-1)" stroke-width="1.2" />
        </svg>
        <div class="ident">
          <div class="handle cinzel">{PROFILE.handle}</div>
          <div class="role body-italic">{profileClass}</div>
          <div class="guild body-italic">{guild}</div>
        </div>
      </div>
      <dl class="stats">
        <div><dt class="mono">{t.stats.years}</dt><dd class="cinzel">{PROFILE.stats.years}</dd></div>
        <div><dt class="mono">{t.stats.games}</dt><dd class="cinzel">{PROFILE.stats.games}</dd></div>
        <div><dt class="mono">{t.stats.jams}</dt><dd class="cinzel">{PROFILE.stats.jams}</dd></div>
        <div><dt class="mono">{t.stats.vr}</dt><dd class="cinzel">{PROFILE.stats.vr}</dd></div>
      </dl>
    </div>
  </div>
</header>

<style>
  .header {
    display: flex;
    gap: 22px;
    align-items: stretch;
    margin-bottom: 32px;
  }
  .plaque {
    flex: 1.4;
    padding: 11px;
    border-radius: 12px;
    background:
      repeating-linear-gradient(0deg, rgba(20,10,4,0.10) 0%, transparent 1px, transparent 4px),
      linear-gradient(180deg, #8a5e34 0%, #6e4824 50%, #523619 100%);
    box-shadow:
      inset 0 0 0 3px #3a2410,
      inset 0 0 0 5px #9c6e38,
      inset 0 0 0 7px #3a2410,
      0 10px 24px rgba(0,0,0,.55);
  }
  .plaque-inner {
    padding: 18px 28px;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
  }
  .subtitle {
    text-transform: uppercase;
    font-size: 12px;
    letter-spacing: 0.36em;
    color: #e6d6a4;
  }
  .title {
    margin: 0;
    font-weight: 700;
    font-size: 56px;
    letter-spacing: 0.08em;
    color: #fbeec4;
    text-shadow: 0 1px 0 #3b220c;
    line-height: 1.05;
  }
  .pitch {
    margin: 0;
    font-style: italic;
    font-size: 15.5px;
    color: #f4ecd6;
    max-width: 560px;
  }

  .sticker-wrap {
    flex: 1;
    position: relative;
  }
  .top-controls {
    position: absolute;
    top: -10px;
    right: 0;
    z-index: 5;
    display: flex;
    gap: 6px;
  }
  .ctrl {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(31,22,12,0.85);
    color: #fbeec4;
    padding: 6px 10px;
    border-radius: 4px;
    font-size: 11px;
    letter-spacing: 0.08em;
    border: 1px solid var(--accent-deep);
    transition: background 150ms ease;
  }
  .ctrl:hover { background: var(--accent-deep); }
  .ctrl svg { flex: 0 0 14px; }

  .sticker {
    position: relative;
    padding: 18px 22px 16px;
    transform: rotate(1.2deg);
    background-color: var(--parchment-2);
    box-shadow:
      0 8px 18px rgba(0,0,0,.32),
      inset 0 0 0 1px rgba(120,80,40,.22),
      inset 0 0 24px rgba(120,80,40,.10);
  }
  .pin {
    position: absolute;
    top: -5px;
    left: 50%;
    transform: translateX(-50%);
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #fff7c6 0%, var(--wax) 55%, #2a1408 100%);
    box-shadow: 0 1px 2px rgba(0,0,0,.45);
  }
  .sticker-grid {
    display: flex;
    gap: 14px;
    align-items: center;
  }
  .ident { flex: 1; }
  .handle {
    font-weight: 700;
    font-size: 20px;
    color: var(--ink-1);
  }
  .role {
    font-size: 13px;
    color: var(--ink-2);
  }
  .guild {
    font-size: 12px;
    color: var(--ink-3);
  }

  .stats {
    margin: 12px 0 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px 18px;
  }
  .stats > div {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-bottom: 1px dotted var(--ink-hair);
    padding: 2px 0;
    gap: 8px;
  }
  .stats dt {
    margin: 0;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-3);
  }
  .stats dd {
    margin: 0;
    font-weight: 700;
    font-size: 18px;
    color: var(--ink-1);
    font-variant-numeric: tabular-nums;
  }

  /* Tablet — keep horizontal layout but shrink everything slightly. */
  @media (max-width: 900px) {
    .header { gap: 14px; }
    .plaque-inner { padding: 14px 20px; }
    .title { font-size: 42px; }
    .pitch { font-size: 14px; }
    .sticker { padding: 16px 18px 14px; }
    .top-controls { top: -8px; }
    .ctrl { font-size: 10px; padding: 5px 8px; }
  }

  /* Mobile — stack vertically, smaller title, compact stats. */
  @media (max-width: 600px) {
    .header {
      flex-direction: column;
      gap: 28px;
      margin-bottom: 24px;
    }
    .plaque,
    .sticker-wrap { flex: none; width: 100%; }
    .plaque-inner { padding: 12px 16px; }
    .subtitle { font-size: 10px; letter-spacing: 0.28em; }
    .title { font-size: 32px; letter-spacing: 0.06em; }
    .pitch { font-size: 13px; }
    .top-controls {
      position: static;
      margin-bottom: 8px;
      justify-content: flex-end;
    }
    .sticker {
      padding: 14px 16px 12px;
      transform: rotate(0.6deg);
    }
    .sticker-grid { gap: 12px; }
    .handle { font-size: 18px; }
    .role { font-size: 12px; }
    .guild { font-size: 11px; }
    .stats { margin-top: 10px; gap: 3px 12px; }
    .stats dd { font-size: 16px; }
  }
</style>
