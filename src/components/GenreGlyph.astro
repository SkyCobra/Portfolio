---
import type { GenreGlyphKind } from '../data/portfolio';

interface Props {
  kind: GenreGlyphKind;
  size?: number;
}

const { kind, size = 16 } = Astro.props;
const common = `width=${size} height=${size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"`;
---
{kind === 'swords' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M4 4l9 9M20 4l-9 9M5 14l5 5M14 14l5 5M11 11l2 2" />
    <circle cx="3.5" cy="3.5" r=".8" fill="currentColor" stroke="none" />
    <circle cx="20.5" cy="3.5" r=".8" fill="currentColor" stroke="none" />
  </svg>
)}
{kind === 'mug' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M6 6h9v12a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2z" />
    <path d="M15 9h2a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2h-2" />
    <path d="M8 10v6M11 10v6" />
  </svg>
)}
{kind === 'arch' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M4 20V12a6 6 0 0 1 12 0v8" />
    <path d="M4 20h12" />
    <path d="M10 20v-5" />
    <circle cx="10" cy="10" r="1" />
  </svg>
)}
{kind === 'scroll' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M6 5h11a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H7" />
    <path d="M6 5a2 2 0 0 0-2 2v1h4V7a2 2 0 0 0-2-2z" />
    <path d="M17 19a2 2 0 0 0 2-2v-1h-4v1a2 2 0 0 0 2 2z" />
    <path d="M9 10h7M9 13h7" />
  </svg>
)}
{kind === 'visor' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <rect x="3" y="8" width="18" height="9" rx="2.5" />
    <circle cx="8.5" cy="12.5" r="1.6" />
    <circle cx="15.5" cy="12.5" r="1.6" />
    <path d="M3 9 7 6h10l4 3" />
  </svg>
)}
{kind === 'star' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 3l2.6 5.6 6 .7-4.5 4.2 1.2 6-5.3-3-5.3 3 1.2-6L3.4 9.3l6-.7z" />
  </svg>
)}
